{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix wraith-app",
  "buildCommand": "npm run build --prefix wraith-app",
  "outputDirectory": "wraith-app/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
